DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_AUTHORIZE_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_OAUTH_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
GOOGLE_OAUTH_SCOPE=openid email profile
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/oauth/complete/?provider=google
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_AUTHORIZE_URL=https://github.com/login/oauth/authorize
GITHUB_OAUTH_TOKEN_URL=https://github.com/login/oauth/access_token
GITHUB_OAUTH_USERINFO_URL=https://api.github.com/user
GITHUB_OAUTH_SCOPE=read:user user:email
GITHUB_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/oauth/complete/?provider=github
